generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  OWNER
}

enum ToiletStatus {
  OPEN
  CLOSED
}

enum ToiletType {
  PUBLIC
  PRIVATE
  PAID
  FREE
}

model User {
  id      Int       @id @default(autoincrement())
  name    String
  phone   String    @unique
  password String
  role    String    @default("USER")
  toilets Toilet[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Toilet {
  id         Int      @id @default(autoincrement())
  ownerId    Int
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  lat        Float
  lng        Float
  price      Float    @default(0)
  status     String   @default("OPEN")
  type       String
  images     String?
  avg_rating Float    @default(0)
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lat, lng])
  @@index([status])
  @@map("toilets")
}

model Review {
  id             Int      @id @default(autoincrement())
  userId         Int
  toiletId       Int
  rating         Int
  comment        String?
  quick_feedback String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toilet         Toilet   @relation(fields: [toiletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, toiletId])
  @@index([toiletId])
  @@map("reviews")
}
